<Page x:Class="ElectronicStore.Pages.ManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   
      >
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Панель менеджера" FontSize="24" Margin="0 0 0 20"/>

        <WrapPanel Grid.Row="1">
            <Button Content="Товары" Width="180" Height="60" Margin="5" Click="GoProducts"/>
            <Button Content="Категории" Width="180" Height="60" Margin="5" Click="GoCategories"/>
            <Button Content="Теги" Width="180" Height="60" Margin="5" Click="GoTags"/>
            <Button Content="Бренды" Width="180" Height="60" Margin="5" Click="GoBrands"/>
            <Button Content="Назад" Width="180" Height="60" Margin="5" Click="GoBackProducts"/>
        </WrapPanel>
    </Grid>
</Page>
