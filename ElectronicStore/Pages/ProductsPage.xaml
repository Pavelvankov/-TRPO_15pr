<Page x:Class="ElectronicStore.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ElectronicStore.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      DataContext="{Binding RelativeSource={RelativeSource Self}}"
      Title="Товары">

    <Page.Resources>
        <local:StockToBorderBrushConverter x:Key="StockToBorderBrushConverter"/>
    </Page.Resources>
    <Grid Background="#dfeaeb" Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>

            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>


        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <Label >Поиск</Label>
            <TextBox x:Name="SearchBox" Text="{Binding searchQuery,UpdateSourceTrigger=PropertyChanged}" TextChanged="TextBox_TextChanged" materialDesign:HintAssist.Hint="Введите название товара" Background="#00C4B4"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" >
            <Label FontSize="16">Сортировка</Label>
            <ComboBox x:Name="SortCombo" SelectionChanged="SortCombo_SelectionChanged" Background="#00C4B4">
                <ComboBox.Items>
                    <ComboBoxItem Tag="NameAsc" >По наименованию</ComboBoxItem>
                    <ComboBoxItem Tag="PriceAsc">По возрастанию цены</ComboBoxItem>
                    <ComboBoxItem Tag="PriceDesc">По убыванию цены</ComboBoxItem>
                    <ComboBoxItem Tag="StockAsc">По возрастанию количества</ComboBoxItem>
                    <ComboBoxItem Tag="StockDesc">По убыванию количества</ComboBoxItem>
                </ComboBox.Items>
            </ComboBox>

            <Label>Фильтры</Label>

            <Label>Категория</Label>
            <ComboBox x:Name="CategoryCombo" DisplayMemberPath="Name" SelectionChanged="CategoryCombo_SelectionChanged" Background="#00C4B4"/>
            <Label FontSize="16">Бренд</Label>
            <ComboBox x:Name="BrandCombo" DisplayMemberPath="Name" SelectionChanged="BrandCombo_SelectionChanged" Background="#00C4B4"/>

            <Label FontSize="16">Цена</Label>
            <TextBox x:Name="PriceFromBox" Text="{Binding filterPriceFrom, UpdateSourceTrigger=PropertyChanged}" TextChanged="TextBox_TextChanged" materialDesign:HintAssist.Hint="от" Background="#00C4B4" Margin="0,0,0,10"/>
            <TextBox x:Name="PriceToBox" Text="{Binding filterPriceTo, UpdateSourceTrigger=PropertyChanged}" TextChanged="TextBox_TextChanged" materialDesign:HintAssist.Hint="до" Background="#00C4B4" Margin="0,0,0,10"/>
            <TextBlock x:Name="Error" Foreground="Red" FontSize="12" Margin="10 0 10 0" Visibility="Collapsed"/>
            <Button Click="ResetFilters" Margin="0,0,0,10">Сбросить</Button>
            <Button x:Name="ManagerPanelButton" Margin="0,0,0,10" Visibility="Collapsed" Click="ManagerPanelButton_Click">Панель менеджера</Button>
        </StackPanel>

   
        <materialDesign:ColorZone Grid.Row="1" Grid.Column="1" Mode="SecondaryMid">
            <ListView x:Name="ProductsList" ItemsSource="{Binding products}" HorizontalContentAlignment="Stretch" Background="#00b4c4" ContextMenuClosing="ProductsList_ContextMenuClosing">

                <ListView.ItemTemplate>
                    <DataTemplate>

                        <Border BorderBrush="{Binding Stock, Converter={StaticResource StockToBorderBrushConverter}}" BorderThickness="2" Background="White" Padding="10" Margin="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                            HorizontalAlignment="Right">
                                    <Run Text="{Binding Price, StringFormat={}{0:F2}}"/>
                                    <Run Text=" ₽"/>
                                </TextBlock>

            
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FontSize="12" >
                                    <Run Text="⭐"/>
                                    <Run Text="{Binding Rating, StringFormat={}{0:F1}}"/>
                                </TextBlock>

                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" FontSize="12">
                                    <Run Text="{Binding Category.Name}"/>
            
                                </TextBlock>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding Description}" FontSize="12"/>

                                <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" FontSize="12"
                                           Margin="8,2,0,0">
                                    <Run Text="Остаток: "/>
                                    <Run Text="{Binding Stock}"/>
                                </TextBlock>

                    
                                <ItemsControl Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" ItemsSource="{Binding Tags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock >
                                                <Run Text="#"/>
                                                <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </materialDesign:ColorZone>

        <WrapPanel Grid.Row="2" Grid.ColumnSpan="2">
            <TextBlock Text="{Binding products.Count, StringFormat='{}Всего товаров: {0}'}"/>
            <TextBlock Text="{Binding Items.Count, ElementName=ProductsList, StringFormat='{} · Показано: {0}'}"/>
        </WrapPanel>
    </Grid>
</Page>
