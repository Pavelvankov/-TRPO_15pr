<Page x:Class="ElectronicStore.Pages.ProductsManagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  
      >
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            <TextBlock Text="Товары" FontSize="22" VerticalAlignment="Center"/>
            <Button Content="Назад" Margin="20 0 0 0" Click="GoBack"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListView x:Name="ItemsList" SelectionChanged="ItemsList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" Padding="4"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Label Content="Название"/>
                    <TextBox x:Name="NameBox"/>

                    <Label Content="Описание"/>
                    <TextBox x:Name="DescriptionBox"  TextWrapping="Wrap" Height="60" AcceptsReturn="True"/>

                    <Label Content="Цена"/>
                    <TextBox x:Name="PriceBox" />

                    <Label Content="Количество"/>
                    <TextBox x:Name="StockBox"/>

                    <Label Content="Рейтинг"/>
                    <TextBox x:Name="RatingBox"/>

                    <Label Content="Дата добавления"/>
                    <TextBox x:Name="CreatedAtBox" />

                    <Label Content="Категория"/>
                    <ComboBox x:Name="CategoryCombo" DisplayMemberPath="Name"/>

                    <Label Content="Бренд"/>
                    <ComboBox x:Name="BrandCombo" DisplayMemberPath="Name"/>

                    <Label Content="Теги"/>
                    <ListBox x:Name="TagsList" DisplayMemberPath="Name"
                             SelectionMode="Multiple" Height="100"/>

                    <StackPanel Orientation="Horizontal"  Margin="5">
                        <Button Content="Очисить" Width="150" Height="30"  Margin="0 0 5 0" Click="AddNew"/>
                        <Button Content="Добавить" Width="150" Height="30"  Margin="0 0 5 0" Click="Save"/>
                        <Button Content="Удалить" Width="150" Height="30" Margin="0 0 5 0" Click="Delete"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
