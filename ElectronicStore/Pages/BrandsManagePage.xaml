<Page x:Class="ElectronicStore.Pages.BrandsManagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            <TextBlock Text="Бренды" FontSize="22" VerticalAlignment="Center"/>
            <Button Content="Назад" Margin="20 0 0 0" Click="GoBack"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListView x:Name="ItemsList" SelectionChanged="ItemsList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" Padding="4"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Column="1" Margin="15 0 0 0">
                <Label Content="Название"/>
                <TextBox x:Name="NameBox" Margin="0 0 0 15"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Добавить" Width="150" Height="60" Margin="0 0 5 0" Click="Save"/>
                    <Button Content="Очистить" Width="150" Height="60" Margin="0 0 5 0" Click="Clear"/>
                    <Button Content="Удалить" Width="150" Height="60" Click="Delete"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
